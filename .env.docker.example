# ─────────────────────────────────────────────────────────
# MASSOTERIC — Docker Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this to .env and fill in your values
# Or use GitHub Secrets for deployment

# ─────────────────────────────────────────────────────────
# DATABASE (Auto-configured by Docker Compose)
# ─────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=massoteric
POSTGRES_PORT=5432

# ─────────────────────────────────────────────────────────
# NEXT.JS APP
# ─────────────────────────────────────────────────────────
APP_PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Massoteric

# ─────────────────────────────────────────────────────────
# CLERK AUTHENTICATION
# Get from: https://dashboard.clerk.com
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/feed
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ─────────────────────────────────────────────────────────
# STRIPE PAYMENTS
# Get from: https://dashboard.stripe.com/apikeys
# ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_PRICE_STANDARD=price_xxxxx
STRIPE_PRICE_PRO=price_xxxxx

# ─────────────────────────────────────────────────────────
# POLYMARKET API
# ─────────────────────────────────────────────────────────
POLYMARKET_API_BASE=https://gamma-api.polymarket.com

# ─────────────────────────────────────────────────────────
# KALSHI API (Optional)
# ─────────────────────────────────────────────────────────
KALSHI_API_BASE=https://trading-api.kalshi.com/trade-api/v2
KALSHI_API_KEY=

# ─────────────────────────────────────────────────────────
# ADMIN
# ─────────────────────────────────────────────────────────
ADMIN_USER_IDS=dev-user-123,your-clerk-user-id
